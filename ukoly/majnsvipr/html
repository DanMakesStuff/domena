    function randomNumber(min,max){
        return Math.floor(Math.random()*(max-min+1)+min);
    } 
    let game = false
    let mines = []
    let amountOfMines = 70
    let tiles = document.getElementsByClassName("tile")
    let tileArray = Array.from(tiles)

