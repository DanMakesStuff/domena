        tiles[index].setAttribute("id",index)
    }

    function hracKlikl(tile){
        if (game==false) {
                game=true;
                mineCount();
                for (let i = 0; i < amountOfMines; i++) {
                    let rnumber = randomNumber(0,399);
                    while (mines.includes(rnumber) && mines.length !== amountOfMines && rnumber != tile.id) {
